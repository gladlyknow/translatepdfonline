# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules

# pnpm 10/11 在存在 ignored build scripts 时会自动生成 pnpm-workspace.yaml 占位文件
# （仅含 allowBuilds 提示、无 packages 字段），会导致 Cloudflare `pnpm install --frozen-lockfile`
# 报 "packages field missing or empty"。本项目为单包，不需要 workspace 文件，忽略其本地再生。
/pnpm-workspace.yaml
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local
.env.development
.env.test
.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

data*
*debug*

*.db

.open-next
.wrangler
src/shared/types/cloudflare.d.ts

src/config/db/migrations*

.debug 
.test

*.sql
.source

.chats