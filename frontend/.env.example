# app
NEXT_PUBLIC_APP_URL = "http://localhost:3000"
NEXT_PUBLIC_APP_NAME = "Your App Name"
# 与 public/preview.png 实际像素一致（OG/Twitter）；更换预览图时请同步修改
# NEXT_PUBLIC_APP_PREVIEW_IMAGE_WIDTH = "2540"
# NEXT_PUBLIC_APP_PREVIEW_IMAGE_HEIGHT = "1270"
# AdSense（与控制台一致，需 ca-pub- 前缀）：
# - 生产：管理后台 Settings → Adsense 写入 adsense_code；或构建/Worker 环境变量 ADSENSE_CODE（与后台字段同名，大写）。
# - 本地无库或未配后台：设 NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-xxxx 后 /ads.txt 与 <head> 脚本才会非空。
# NEXT_PUBLIC_ADSENSE_CLIENT = "ca-pub- "
# ADSENSE_CODE = "ca-pub- "

# theme
NEXT_PUBLIC_THEME = "default"

# appearance
NEXT_PUBLIC_APPEARANCE = "system"

# database
DATABASE_PROVIDER = "postgresql"
# --- Supabase / Postgres（密码勿提交 Git）---
# Transaction pooler（:6543）：...pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct（:5432）：...@db.[ref].supabase.co:5432/postgres
# Local / CI build：`.env.development` 或构建环境注入 DATABASE_URL。
#
# --- Cloudflare Worker + Hyperdrive（推荐，见 wrangler.toml.template [[hyperdrive]]）---
# 1) Dashboard 创建 Hyperdrive，**Origin** 填 Supabase 连接串（与官方「配置 Hyperdrive」一致）。
# 2) Worker 绑定 `HYPERDRIVE`，`pnpm` 前设 HYPERDRIVE_CONFIG_ID 或手改生成的 wrangler.toml 中 id。
# 3) 可同时保留 Encrypted `DATABASE_URL`（同源 Supabase）；无 HYPERDRIVE 绑定时用此串连库。
# 4) 本地 wrangler dev：优先 `CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE`，勿把密码写进仓库。
DATABASE_URL = ""
# WRANGLER_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE = ""
# Cloudflare Worker 部署：Shipany 文档要求 DB_SINGLETON_ENABLED = "false"
DB_SINGLETON_ENABLED = "true"
DB_MAX_CONNECTIONS = "1"
# Drizzle（默认与 src/config/index.ts 一致，一般不必改）
# DB_SCHEMA_FILE = "./src/config/db/schema.postgres.ts"
# DB_MIGRATIONS_OUT = "./src/config/db/migrations"

# auth secret
# openssl rand -base64 32
AUTH_SECRET = ""
# 临时排错：Worker 日志输出 hasPostgresRuntimeConfig / cfContext 等（勿长期开）
# AUTH_DB_DIAG = "1"
# 开发/运维：GET /api/dev/verify-db?secret=xxx&email=xxx 验证 PG 与管理员身份
VERIFY_DB_SECRET = ""
# Optional: comma-separated extra origins for auth (e.g. workers.dev preview URL)
# AUTH_TRUSTED_ORIGINS = "https://xxx.workers.dev"

# Google 登录：仅用户打开登录弹窗并点「Google」时走 OAuth 重定向；不加载 gsi/client、无页面加载自动弹窗。

# R2 (PDF upload/preview for translate) - code reads R2_BUCKET and R2_ENDPOINT
R2_BUCKET = ""
R2_ACCOUNT_ID = ""
R2_ACCESS_KEY_ID = ""
R2_SECRET_ACCESS_KEY = ""
# optional; default https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT = ""
# 浏览器可匿名 GET 的公网基址（推荐 R2 自定义域绑定到桶根），用于 PDF 第 1 页直链预览，减轻 Worker 内存。
# 与 R2_ENDPOINT 不可互换：R2_ENDPOINT 是 S3 兼容 API（签名/预签名/读写）；R2_PUBLIC_URL 是给前端的直链前缀。
# 未配置时 API 仍会对第 1 页回退 createPresignedGet（预签名 URL），大文件不再误 413。
# 任选其一；不要重复拼桶名在 base 里（拼接见 translate-r2 encodeR2KeyForPublicUrl）。
# 站点域与存储域不同时，请在 R2 桶 CORS 中允许应用来源对 PDF 的 GET/HEAD。
# R2_PUBLIC_URL = "https://storage.example.com"
# NEXT_PUBLIC_R2_PUBLIC_URL = "https://storage.example.com"

# 翻译 FC（仅本地；线上见 docs/cloudflare-env-真相.md）
TRANSLATE_FC_URL = ""
TRANSLATE_FC_SECRET = ""
# 可选：Worker 调用 FC 的 fetch 超时（毫秒），默认 600000（10min），范围 60000–900000
# TRANSLATE_FC_FETCH_TIMEOUT_MS = 600000

# Creem 订阅免费试用：Webhook subscription.trialing 时发放的积分（需与定价页 trial_subscription 商品一致）
TRIAL_CREDITS_AMOUNT = "50"
# 与 Creem 产品试用天数一致；积分过期仍以 Webhook 周期为准
TRIAL_CREDITS_DAYS = "3"

# 新用户注册赠送积分（与后台 Settings → Credit 中 initial_credits_* 同名；大写 env 会覆盖 DB）
# 代码默认：开启赠送、30 积分、说明 Welcome bonus；仅改代码默认值不会更新已有库里的 config 行，请在后台确认或设下列变量。
# Cloudflare：可加入构建/Worker 变量；generate-wrangler 会把 INITIAL_CREDITS_* 写入 wrangler.toml [vars]。
# INITIAL_CREDITS_ENABLED = "true"
# INITIAL_CREDITS_AMOUNT = "30"
# INITIAL_CREDITS_DESCRIPTION = "Welcome bonus"