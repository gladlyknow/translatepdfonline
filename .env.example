# 复制为 .env 并填写实际值。FC 翻译相关变量见 DEPLOYMENT.md 与 docs/FC_DEPLOY_GUIDE.md

# DATABASE_URL=postgres://user:pass@host:5432/dbname
# REDIS_URL=redis://localhost:6379/0
# FRONTEND_ORIGINS=http://localhost:3000

# 阿里云 FC 做翻译时必填 / 可选
# BABELDOC_USE_FC=true
# BABELDOC_FC_SPEC=cpu
# BABELDOC_FC_URL_CPU=https://translate-cpu-xxx.us-east-1.fcapp.run/translate
# BABELDOC_FC_URL_GPU=https://translate-gpu-xxx.us-east-1.fcapp.run/translate
# BABELDOC_FC_URL=https://translate-cpu-xxx.fcapp.run/translate
# BABELDOC_FC_SECRET=your-fc-secret
# BABELDOC_FC_TIMEOUT_SECONDS=600
